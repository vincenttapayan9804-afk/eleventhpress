# Postgres connection strings. If you provision through Vercel's Storage
# tab, these are injected automatically under these exact names — nothing
# to fill in by hand. For any other provider (Neon, Supabase, RDS, etc.),
# set both yourself: POSTGRES_PRISMA_URL to a pooled connection string
# (or the same value as below if your provider doesn't offer pooling),
# POSTGRES_URL_NON_POOLING to a direct connection string (Prisma needs
# this one to run migrations).
POSTGRES_PRISMA_URL=postgresql://user:password@host:5432/dbname
POSTGRES_URL_NON_POOLING=postgresql://user:password@host:5432/dbname
