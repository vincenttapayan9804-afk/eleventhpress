# Postgres connection strings. If you provision through Vercel's Storage
# tab, these are injected automatically under these exact names — nothing
# to fill in by hand. For any other provider (Neon, Supabase, RDS, etc.),
# set both yourself: POSTGRES_PRISMA_URL to a pooled connection string
# (or the same value as below if your provider doesn't offer pooling),
# POSTGRES_URL_NON_POOLING to a direct connection string (Prisma needs
# this one to run migrations).
POSTGRES_PRISMA_URL=postgresql://user:password@host:5432/dbname
POSTGRES_URL_NON_POOLING=postgresql://user:password@host:5432/dbname

# Required in production — signs session tokens. The app refuses to start
# in production without it (see src/lib/auth.ts). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Required to enable the cron sweep endpoints (src/app/api/cron/**) — each
# fails closed (403) until this is set. Vercel Cron sends this as a Bearer
# Authorization header automatically once configured in vercel.json.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET=

# Optional, free tier — enables real per-IP rate limiting on the login and
# register endpoints (src/lib/ratelimit.ts) via Upstash's serverless
# Redis. Without both of these set, rate limiting runs in a clearly-
# labeled simulation mode: the request always proceeds and a console
# warning names these two vars, so brute-force protection is honestly
# absent rather than silently faked as enforced. Sign up at upstash.com
# (free tier), create a Redis database, copy the REST URL/token from its
# dashboard.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Enables real file uploads (manuscripts). If provisioned through Vercel's
# Storage tab (connect a Blob store), this is injected automatically —
# nothing to fill in by hand. Without it, uploads fall back to a local-disk
# dev mode that does not work on Vercel's read-only serverless filesystem.
BLOB_READ_WRITE_TOKEN=

# Optional — enables real LLM-assisted editorial triage (src/lib/llm.ts,
# backed by the Anthropic Messages API). Without it, triage falls back to
# a deterministic heuristic (keyword matching, no LLM call) automatically.
ANTHROPIC_API_KEY=

# Optional, free tier — enables real malware scanning of every uploaded
# file via VirusTotal (src/lib/virustotal.ts) instead of trusting the
# client-supplied Content-Type outright. 500 requests/day at no cost. Sign
# up at virustotal.com, then Profile -> API Key. Without this, scans still
# run (job created, cron-swept) but complete honestly with no verdict —
# StorageObject.malwareScanStatus is set to SKIPPED, never fabricated as
# clean.
VIRUSTOTAL_API_KEY=

# Optional, free — mints real, permanently-resolving DOIs via Zenodo on
# publish (src/lib/zenodo.ts) instead of a fake, non-resolving DOI. No cost
# at any scale: sign up at zenodo.org, then Applications -> Personal access
# tokens -> New token (scopes: deposit:write, deposit:actions). Zenodo
# records are auto-harvested by OpenAIRE and surfaced in BASE/CORE, so this
# is the cheapest path to real indexing before a paid Crossref membership.
ZENODO_TOKEN=
# Set to "production" to deposit to the real Zenodo (zenodo.org) instead of
# its sandbox (sandbox.zenodo.org) — leave unset while testing.
ZENODO_ENV=

# Optional — enables real Blogger auto-publish (Tier A article syndication,
# src/lib/blogger.ts): authors connect their Google account once from the
# Distribution tab, then every "Publish to Blogger" click genuinely posts
# via the Blogger API v3, no copy-pasting required. Create an OAuth 2.0
# Client ID at console.cloud.google.com (APIs & Services -> Credentials),
# enable the Blogger API, and add {APP_BASE_URL}/api/auth/blogger/callback
# as an authorized redirect URI. Without these, the connect/publish flow
# runs in a clearly-labeled simulated mode instead (no real network call).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional — enables real typo-tolerant, ranked keyword search (Resources
# page, article browse) via Meilisearch (src/lib/meilisearch.ts) instead of
# the plain Postgres `contains` query used otherwise. Meilisearch is a
# long-lived server, so it can't run inside Vercel's serverless functions
# itself — the free tier of Meilisearch Cloud (meilisearch.com) is the
# zero-infra path: create a project there, then set both values below. Self-
# hosting is also possible (Cloud Run/Fly.io/a VPS — same pattern as the
# Pandoc worker in mini-services/, see docs/deployment.md). Without these,
# search falls back to the existing Postgres query automatically.
MEILISEARCH_HOST=
MEILISEARCH_API_KEY=
