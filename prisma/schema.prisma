// ELEVENTH PRESS INTERNATIONAL PUBLISHING - Prisma Schema
// Multidisciplinary Journal Platform

generator client {
  provider      = "prisma-client-js"
  // Vercel's serverless functions run on Amazon Linux, not this build
  // machine's platform — without an explicit target for it, Prisma only
  // bundles the query engine binary for whatever OS built the project,
  // and the deployed function fails at runtime with "query engine not
  // found." "native" keeps local dev working.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  // POSTGRES_PRISMA_URL / POSTGRES_URL_NON_POOLING are the names Vercel's
  // native Postgres storage integration auto-injects into a connected
  // project — no manual env var entry needed if you provision through
  // Vercel's Storage tab. If you're using a different provider (Neon,
  // Supabase, RDS, etc. directly), set both env vars yourself: url to a
  // pooled/pgbouncer connection string if your provider offers one (fall
  // back to the same value as directUrl if not), directUrl to a direct
  // (non-pooled) connection string — Prisma needs the direct one to run
  // migrations.
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// ---------------------------------------------------------------------------
// Identity & Access Management (IAM)
// ---------------------------------------------------------------------------
model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  passwordHash          String
  fullName              String
  affiliation           String?
  orcid                 String?
  // Role: SUPER_ADMIN | EDITOR | ASSOCIATE_EDITOR | REVIEWER | AUTHOR | READER | EXPERT
  role                  String    @default("READER")
  // Only meaningful when role === "EXPERT": CONTRIBUTOR (one-off Expert
  // Insight pieces) | COUNCIL_MEMBER (vetted, committed to recurring
  // monthly insights). Set once by the Prestige Application approval flow
  // (see RoleApplication below) — never self-selected.
  expertTier            String?
  bio                   String?
  expertise             String? // comma-separated keywords for reviewer matching
  country               String?
  // Public profile
  avatarUrl             String? // profile picture — resolved public URL (Blob or /api/storage/download)
  profession            String? // e.g. "Associate Professor of Computational Biology" — distinct from `affiliation` (institution name)
  website               String?
  twitterUrl            String?
  linkedinUrl           String?
  githubUrl             String?
  contactEmail          String? // public-facing contact address — deliberately separate from the login `email`
  contactPhone          String?
  // Two-factor authentication (TOTP) — twoFactorSecret is only set while
  // enabled; twoFactorBackupCodes is a comma-separated list of bcrypt
  // hashes (never plaintext), one-time use, consumed on redemption.
  twoFactorSecret       String?
  twoFactorEnabled      Boolean   @default(false)
  twoFactorBackupCodes  String?
  // Account-lockout brute-force hardening, layered on top of the existing
  // per-IP/per-account rate limit (src/lib/ratelimit.ts) rather than
  // replacing it — the rate limit is the fast, cheap first line (and fails
  // open without Upstash configured); this is a slower-to-trip, DB-backed
  // second line that still holds even when Upstash isn't set up. Reset to
  // 0/null on every successful login (src/app/api/auth/login/route.ts).
  failedLoginCount      Int       @default(0)
  lockedUntil           DateTime?
  // ORCID OAuth tokens (premium integration)
  orcidAccessToken      String?
  orcidRefreshToken     String?
  orcidTokenExpiry      DateTime?
  orcidLastSync         DateTime?
  // Blogger OAuth tokens (Tier A article syndication — real API auto-publish)
  bloggerAccessToken    String?
  bloggerRefreshToken   String?
  bloggerTokenExpiry    DateTime?
  bloggerBlogId         String?
  bloggerBlogUrl        String?
  bloggerConnectedAt    DateTime?
  // Institutional affiliation (premium IP-auth feature)
  institutionId         String?
  // Real scholarly-output metrics from OpenAlex (src/lib/citation-metrics.ts),
  // by ORCID — only meaningful for editorial-board accounts (SUPER_ADMIN/
  // EDITOR/ASSOCIATE_EDITOR) and only populated when `orcid` is set.
  // Refreshed unconditionally on every deploy alongside Article.citations
  // (scripts/refresh-citation-metrics.ts); GET /api/editorial-board also
  // tries a live fetch first and only falls back to these cached values.
  boardWorksCount       Int?
  boardCitedByCount     Int?
  boardHIndex           Int?
  boardMetricsCheckedAt DateTime?
  // GDPR/CCPA right-to-erasure marker. Set by /api/account/delete, which
  // anonymizes this row in place rather than deleting it — the account has
  // ~30 enforced FK relations (submissions, reviews, invoices, audit log…)
  // and, per GDPR Art. 17(3)(d), the already-published scholarly record
  // (DOI-bearing articles, citable peer-review reports) is exempt from
  // erasure as archiving in the public interest. Login is rejected once set.
  deletedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  submissions                    Article[]              @relation("AuthorArticles")
  assignedReviews                Review[]               @relation("ReviewerReviews")
  editorialDecisions             EditorialDecision[]
  readingHistory                 ReadingHistory[]
  collectionsCreated             Collection[]
  expertQuestionsReceived        ExpertQuestion[]       @relation("ExpertQuestionsReceived")
  expertQuestionsAsked           ExpertQuestion[]       @relation("ExpertQuestionsAsked")
  subscriptions                  Subscription[]
  invoices                       Invoice[]
  notifications                  Notification[]
  auditLogs                      AuditLog[]
  institution                    Institution?           @relation(fields: [institutionId], references: [id])
  correctionsIssued              Correction[]
  roleApplications               RoleApplication[]      @relation("ApplicantApplications")
  reviewedApplications           RoleApplication[]      @relation("ReviewerApplications")
  distributionsSubmitted         Distribution[]
  books                          Book[]
  bookDistributionsSubmitted     BookDistribution[]
  royaltyStatementsRecorded      RoyaltyStatement[]
  certificates                   Certificate[]
  authorResponses                AuthorResponse[]
  following                      Follow[]               @relation("Following")
  followedBy                     Follow[]               @relation("Followers")
  articleDownloads               ArticleDownload[]
  magazineIssuesCreated          MagazineIssue[]
  magazineDistributionsSubmitted MagazineDistribution[]
  podcastsCreated                Podcast[]
  podcastEpisodesCreated         PodcastEpisode[]
  podcastDistributionsSubmitted  PodcastDistribution[]
  mediaPostsCreated              MediaPost[]
  narrationJobsCreated           NarrationJob[]
}

// ---------------------------------------------------------------------------
// Follow — lightweight, first-party "follow this expert/author" relation.
// Used by the Council of Experts' Directory ranking (insights + views +
// shares + followers) alongside a future personal reading feed; not
// restricted to EXPERT accounts, since a reader may as reasonably follow a
// prolific research author.
// ---------------------------------------------------------------------------
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Following", fields: [followerId], references: [id])
  following User @relation("Followers", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
  @@index([followingId])
}

// ---------------------------------------------------------------------------
// ArticleDownload — one row per stamped PDF/EPUB download. This is the
// traceability mechanism behind the platform's provenance "Seal of
// Quality": every PDF/EPUB handed out is stamped (visible footer/banner +
// embedded file metadata, see src/lib/watermark.ts) with this row's id, so
// a misattributed or fraudulently-reused copy found in the wild can be
// traced back to who downloaded it and when. This does NOT restrict
// reading, sharing, or reuse — every article is CC BY 4.0, which already
// permits redistribution with attribution. It is provenance, not DRM.
// ---------------------------------------------------------------------------
model ArticleDownload {
  id        String   @id @default(cuid())
  articleId String
  format    String // PDF | EPUB
  userId    String? // null for an unauthenticated/anonymous download
  label     String // display name embedded in the stamp: real name, or "Anonymous reader"
  createdAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@index([articleId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Role Application — qualification workflow for Reviewer / Editor roles
// ---------------------------------------------------------------------------
model RoleApplication {
  id              String  @id @default(cuid())
  userId          String
  // REVIEWER | EDITOR | EXPERT_CONTRIBUTOR | EXPERT_COUNCIL_MEMBER — the
  // last two are the Experts' Insights "Prestige Application Form" tiers;
  // approval of either promotes User.role to the single "EXPERT" value and
  // sets User.expertTier to CONTRIBUTOR/COUNCIL_MEMBER respectively (see
  // src/app/api/applications/[id]/review/route.ts).
  requestedRole   String
  status          String  @default("PENDING") // PENDING | UNDER_REVIEW | APPROVED | REJECTED
  applicationText String?
  orcidId         String?
  expertise       String?
  specializations String?
  // Years of relevant industry/professional experience — the Prestige
  // Application Form's stated 3-5+ year bar for EXPERT_CONTRIBUTOR/
  // EXPERT_COUNCIL_MEMBER applications; unused for REVIEWER/EDITOR.
  yearsExperience Int?

  resumeKey       String?
  transcriptKey   String?
  // JSON array of storage keys — also doubles as the Prestige Application
  // Form's "proof of license or certifications" upload for expert tiers.
  certificateKeys String?

  reviewedBy String?
  reviewedAt DateTime?
  reviewNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applicant User  @relation("ApplicantApplications", fields: [userId], references: [id])
  reviewer  User? @relation("ReviewerApplications", fields: [reviewedBy], references: [id])
}

// "Ask an Expert" — a reader-facing Q&A extension of Experts' Insights
// (User.role === "EXPERT"). Requires a logged-in asker (no anonymous
// questions, same accountability bar as the review/follow features) but
// an expert can still choose to answer privately (isPublic: false) —
// only public, answered questions are ever shown on the expert's profile.
model ExpertQuestion {
  id         String    @id @default(cuid())
  expertId   String
  askedById  String
  question   String
  answer     String?
  answeredAt DateTime?
  isPublic   Boolean   @default(true)
  createdAt  DateTime  @default(now())

  expert  User @relation("ExpertQuestionsReceived", fields: [expertId], references: [id])
  askedBy User @relation("ExpertQuestionsAsked", fields: [askedById], references: [id])

  @@index([expertId, answeredAt])
}

// ---------------------------------------------------------------------------
// Journal metadata
// ---------------------------------------------------------------------------
model Journal {
  id          String   @id @default(cuid())
  name        String
  issn        String?
  publisher   String   @default("Eleventh Press International Publishing")
  description String?
  aimsScope   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles Article[]
  issues   Issue[]
}

model Issue {
  id          String    @id @default(cuid())
  journalId   String
  volume      Int
  issueNumber Int
  year        Int
  title       String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  journal  Journal   @relation(fields: [journalId], references: [id])
  articles Article[]

  @@index([journalId, year, volume, issueNumber])
}

// ---------------------------------------------------------------------------
// Submission & Manuscript Service
// ---------------------------------------------------------------------------
model Article {
  id        String  @id @default(cuid())
  journalId String
  issueId   String?
  doi       String? // e.g. 10.52011/epip.2024.001
  doiStatus String  @default("NONE") // NONE | DRAFT | REGISTERED | PUBLISHED

  title                 String
  abstract              String
  keywords              String // comma-separated
  discipline            String // Physics | Biology | Computer Science | Sociology | etc.
  // Experts' Insights vertical (thought-leadership pieces from vetted
  // industry experts) vs. ordinary peer-reviewed scholarship. Deliberately
  // reuses this same Article model and its whole pipeline — editorial
  // workflow, DOI, distribution, citation export, search indexing — rather
  // than a parallel content type. RESEARCH | EXPERT_INSIGHT
  contentType           String  @default("RESEARCH")
  // Only meaningful when contentType === "EXPERT_INSIGHT". LEGAL_COMPLIANCE
  // | ACADEMIC_PEDAGOGY | BUSINESS_TECHNOLOGY | SCIENTIFIC_CLINICAL |
  // PSYCHOLOGY — the Insights Categories from the Publication Charter.
  insightCategory       String?
  // JSON array of exactly 5 strings — the mandatory "Key Takeaways /
  // Executive Insights" box every Expert Insight article must open with
  // (Enterprise-Grade Formatting charter requirement). Null for RESEARCH
  // articles, which use `laySummary` instead.
  keyTakeaways          String?
  authors               String // JSON array of {name, affiliation, orcid, email}
  correspondingAuthorId String?

  manuscriptKey String? // S3-style key for raw upload
  anonymizedKey String? // S3-style key for double-blind version
  galleyPdfKey  String? // published PDF
  galleyHtmlKey String? // published HTML
  galleyJatsKey String? // published JATS XML
  galleyEpubKey String? // published EPUB3 (single-chapter, src/lib/epub-builder.ts)

  // Workflow state machine
  // DRAFT | SUBMITTED | UNDER_REVIEW | REVISIONS_REQUIRED | ACCEPTED | IN_PRODUCTION | PUBLISHED | REJECTED | WITHDRAWN
  status           String    @default("DRAFT")
  // Preprint server: the corresponding author (or an editor) can opt to
  // make a pre-decision manuscript publicly readable before/during peer
  // review — src/lib/article.ts's PREPRINT_ELIGIBLE_STATUSES,
  // src/app/api/preprints/*. Orthogonal to `status` (never a status value
  // itself) so this never touches the existing workflow state machine or
  // any of the role-based visibility logic keyed on it.
  isPreprint       Boolean   @default(false)
  preprintPostedAt DateTime?
  reviewModel      String    @default("DOUBLE_BLIND") // SINGLE_BLIND | DOUBLE_BLIND | OPEN
  openReview       Boolean   @default(false) // If true, completed reviews are made public (with real reviewer identities) when article is published — signed open review

  // Independent of openReview above (an editor could enable either, both,
  // or neither) — Review History tab (src/app/api/articles/[id]/review-
  // history/route.ts). Shows anonymized reviewer numbering ("Reviewer 1",
  // computed at read time from Review.createdAt order, never stored)
  // instead of real names, plus AuthorResponse entries and published
  // EditorialDecision.letterBody letters. This is the transparent-but-
  // anonymous mode; openReview above is the signed mode.
  //
  // Defaults true (platform-wide policy: every article gets a public
  // Review History automatically) — an editor can still disable it per
  // article from the Editorial queue dashboard for a genuine edge case,
  // but nothing has to opt in anymore. Existing rows created before this
  // default changed don't get rewritten by a column-default change alone
  // (Postgres defaults only apply to new inserts), so
  // scripts/enable-review-history.ts does the one-time catch-up — see
  // its header comment.
  anonymizedReviewHistory Boolean @default(true)

  // Real, citable DOI for the compiled review-round report — minted via
  // the same free Zenodo deposit path already used for the article's own
  // record (src/lib/zenodo.ts depositArticleToZenodo), see
  // depositReviewReportToZenodo. Only ever attempted when
  // anonymizedReviewHistory is true; NONE/null honestly means "not
  // deposited", never a fabricated identifier.
  reviewReportDoi            String?
  reviewReportZenodoRecordId String?
  reviewReportDepositedAt    DateTime?
  reviewReportDepositLog     String? // JSON-stringified deposit response/error, mirrors the article's own zenodoDepositLog

  // Post-publication integrity status — independent of the editorial
  // workflow `status` above, since a PUBLISHED article can later be
  // corrected or retracted without re-entering the submission pipeline.
  // Reflects the most recent Correction issued (see the Correction model);
  // full history lives there, this is just the current-state summary shown
  // on the article page. NORMAL | CORRECTED | UNDER_CONCERN | RETRACTED
  integrityStatus String @default("NORMAL")

  // Real in-corpus similarity check (cosine similarity of this article's
  // embedding against every other article's, via src/lib/manuscript-checks.ts)
  // — catches duplicate/self-plagiarized submissions against this platform's
  // own corpus. Not a substitute for a full Crossref Similarity Check /
  // iThenticate subscription (which checks against a much larger index and
  // requires paid credentials this environment doesn't have); see
  // docs/standards.md for the scope note.
  plagiarismScore     Float?
  similarityReport    String? // JSON: [{articleId, title, score}] top in-corpus matches
  similarityCheckedAt DateTime?

  // Enterprise-tier integrity check via Turnitin's iThenticate API
  // (src/lib/ithenticate.ts, IntegrityCheckJob below) — a real, additional
  // check alongside (not replacing) the in-house pgvector similarity
  // screen above. Always editor-triggered, never run automatically at
  // publish time, since each submission carries a real per-check vendor
  // cost. Denormalized here as "latest result"; full job history lives on
  // IntegrityCheckJob.
  ithenticateScore     Float?
  ithenticateReportUrl String?
  ithenticateCheckedAt DateTime?

  // LLM-assisted checks (src/lib/manuscript-checks.ts) — both optional,
  // author/editor-triggered, never run silently.
  laySummary           String?
  aiKeywordSuggestions String? // JSON array of suggested keyword strings
  statisticalFlags     String? // JSON array of {flag, severity, explanation}
  statisticalCheckedAt DateTime?
  styleFlags           String? // JSON array of {flag, severity, explanation} — house-style consistency, see checkHouseStyle()
  styleCheckedAt       DateTime?

  // AI-assisted abstract translation, feeding the site's existing 5-locale
  // i18n (src/messages/*.json) rather than being a UI-only translation.
  // Editor/author-triggered per locale, never auto-run at publish time.
  // English excluded — the `abstract` field above is already canonical
  // English. On translation failure there is no offline fallback, so the
  // per-locale meta's mode records "heuristic" and callers must show an
  // explicit "unavailable" state rather than presenting the original
  // English text as if it were translated.
  abstractTranslations    String? // JSON: {es, fr, fil, "zh-Hans": text}
  abstractTranslationMeta String? // JSON: {locale: {mode, model, translatedAt}}

  // AI glossary of complex/technical terminology (src/lib/glossary.ts) —
  // the one AI feature in this file that's auto-generated at galley-
  // generation/publish time rather than editor/author-triggered, per
  // explicit product decision. No offline fallback exists (a fabricated
  // definition is worse than none), so glossaryMeta.mode "unavailable"
  // means callers must show an explicit "not available" state, not an
  // empty list styled as "no complex terms."
  glossary     String? // JSON: [{term, definition}]
  glossaryMeta String? // JSON: {mode, model, generatedAt}

  // Paid Distribution Package (revenue Phase 6) — unlocks Tier B
  // (arXiv/SSRN) submission package generation in src/lib/distribution.ts.
  // Tier C share kits and Tier A Blogger auto-publish stay free.
  distributionPackagePaidAt DateTime?

  // Funders — JSON array of {name, id?} (id = a Crossref Open Funder
  // Registry / ROR identifier where known). Lets authors under a funder
  // mandate (e.g. NIH, Plan S signatories) prove compliance through
  // deposited metadata.
  funders String?

  // Individual APC fee waiver (Plan S requires waivers be genuinely
  // available on request, not just theoretically offered)
  apcWaiverRequested Boolean @default(false)
  apcWaiverReason    String?
  apcWaiverStatus    String  @default("NONE") // NONE | REQUESTED | APPROVED | DENIED

  // Crossref deposit tracking
  crossrefBatchId     String? // Crossref-assigned batch ID after successful deposit
  crossrefDepositedAt DateTime?
  crossrefDepositLog  String? // JSON-stringified response / error log

  // Zenodo deposit tracking — the free, real-DOI alternative used for the
  // article's own DOI when no paid Crossref membership exists yet (see
  // src/lib/zenodo.ts's depositArticleToZenodo). Distinct from the
  // per-dataset DatasetLink.zenodoDepositId, which is for supplementary
  // datasets, not the article's own record.
  zenodoRecordId   String?
  zenodoDepositLog String? // JSON-stringified response / error log

  submittedAt DateTime?
  acceptedAt  DateTime?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  views     Int @default(0)
  downloads Int @default(0)
  // Incremented by the share/copy-link action on the article page and the
  // Distribution "share kit" flows. Used, alongside insight count and
  // views, to rank the Council of Experts' Directory.
  shares    Int @default(0)

  // Real citation count from OpenAlex (src/lib/citation-metrics.ts),
  // refreshed unconditionally on every deploy by
  // scripts/refresh-citation-metrics.ts (same build-pipeline precedent as
  // the glossary/lay-summary backfill) — not a one-time backfill, since a
  // citation count needs to keep changing after it's first set. 0/null
  // honestly reflects "not yet cited" or "not yet indexed by OpenAlex",
  // never an estimate.
  citations              Int       @default(0)
  citationsCheckedAt     DateTime?
  citationsPercentileMin Int? // OpenAlex cited_by_percentile_year.min, when computed for this work
  citationsPercentileMax Int?

  // Digital provenance — a real, verifiable "Seal of Quality" for the
  // published record itself (same hash/verify pattern as Certificate, just
  // applied to a work instead of a person's credential). Computed once, at
  // the PUBLISH transition, over the record's locked-in metadata plus the
  // actual bytes of the generated PDF/EPUB galleys — see
  // src/lib/article-provenance.ts. Any later alteration of the metadata or
  // either file breaks the match at /verify/article/[id]. Null for
  // articles published before this field existed, or not yet published.
  // This proves authenticity/integrity; it does not restrict redistribution
  // — every article is still CC BY 4.0, see ArticleDownload below.
  contentHash    String?
  galleyPdfHash  String? // SHA-256 of the exact PDF bytes hashed into contentHash
  galleyEpubHash String? // SHA-256 of the exact EPUB bytes hashed into contentHash, when an EPUB exists

  journal                    Journal                        @relation(fields: [journalId], references: [id])
  issue                      Issue?                         @relation(fields: [issueId], references: [id])
  author                     User?                          @relation("AuthorArticles", fields: [correspondingAuthorId], references: [id])
  reviews                    Review[]
  decisions                  EditorialDecision[]
  invoices                   Invoice[]
  notifications              Notification[]
  auditLogs                  AuditLog[]
  datasets                   DatasetLink[]
  embedding                  ArticleEmbedding?
  chunks                     ArticleChunk[]
  galleyTranslations         ArticleGalleyTranslation[]
  similarityExplanationsFrom ArticleSimilarityExplanation[] @relation("SimilarityExplanationSource")
  similarityExplanationsTo   ArticleSimilarityExplanation[] @relation("SimilarityExplanationTarget")
  readingHistory             ReadingHistory[]
  collectionEntries          CollectionArticle[]
  authorResponses            AuthorResponse[]
  triageReport               EditorialTriageReport?
  corrections                Correction[]
  references                 Reference[]
  distributions              Distribution[]
  bookChapters               BookArticle[]
  downloadStamps             ArticleDownload[]
  independentReviews         IndependentReview[]

  // Composite indexes mirror the actual query shapes used across the app:
  // public/browse listing and the dashboard queue both filter by status
  // (and often journal/discipline) then sort by publishedAt — a single-
  // column index on status alone still forces a sort step at scale.
  @@index([status, publishedAt])
  @@index([journalId, publishedAt])
  @@index([discipline, publishedAt])
  @@index([contentType, publishedAt])
  @@index([issueId])
  @@index([correspondingAuthorId])
  @@index([doi])
}

// ---------------------------------------------------------------------------
// Corrections, errata, expressions of concern, and retractions.
// Per COPE/ICMJE convention (see docs/ojs-interop.md's sibling,
// docs/standards.md, for sources): a Corrigendum fixes an author error, an
// Erratum fixes a publisher error, an Expression of Concern flags unresolved
// doubt pending investigation, and a Retraction withdraws the findings
// entirely. Each gets its own notice, its own DOI, and — once deposited —
// a Crossmark registration so readers see the update even after the PDF
// has already been downloaded.
// ---------------------------------------------------------------------------
model Correction {
  id          String   @id @default(cuid())
  articleId   String
  type        String // CORRIGENDUM | ERRATUM | EXPRESSION_OF_CONCERN | RETRACTION
  title       String
  description String
  doi         String? // DOI minted for this correction/retraction notice itself
  issuedById  String
  issuedAt    DateTime @default(now())

  // Crossmark / Crossref update registration
  crossmarkRegisteredAt DateTime?
  crossrefDepositLog    String? // JSON-stringified deposit response, mirrors Article's own field

  createdAt DateTime @default(now())

  article  Article @relation(fields: [articleId], references: [id])
  issuedBy User    @relation(fields: [issuedById], references: [id])
}

// ---------------------------------------------------------------------------
// References — author-submitted bibliography, validated against OpenAlex
// (a free, keyless scholarly-metadata index; see src/lib/citations.ts and
// docs/standards.md) so editors can see which cited works are genuinely
// findable before publication.
// ---------------------------------------------------------------------------
model Reference {
  id            String    @id @default(cuid())
  articleId     String
  rawText       String // the citation as pasted by the author
  status        String    @default("PENDING") // PENDING | VALID | NOT_FOUND | AMBIGUOUS
  doi           String? // resolved DOI, if found
  resolvedTitle String? // title OpenAlex matched it to
  openAlexId    String?
  checkedAt     DateTime?
  createdAt     DateTime  @default(now())

  article Article @relation(fields: [articleId], references: [id])

  @@index([articleId])
}

// ---------------------------------------------------------------------------
// Workflow & Peer Review Service
// ---------------------------------------------------------------------------
model Review {
  id         String    @id @default(cuid())
  articleId  String
  reviewerId String
  // INVITED | ACCEPTED | DECLINED | IN_PROGRESS | COMPLETED
  status     String    @default("INVITED")
  dueDate    DateTime?

  // Review form (flexible, discipline-agnostic)
  overallScore       Int? // 1-5
  recommendation     String? // ACCEPT | MINOR_REVISIONS | MAJOR_REVISIONS | REJECT
  confidence         Int? // 1-5
  commentsToAuthor   String?
  commentsToEditor   String?
  conflictOfInterest Boolean @default(false)

  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Open peer review: set to true when article is published with openReview enabled
  madePublic Boolean @default(false)

  article  Article @relation(fields: [articleId], references: [id])
  reviewer User    @relation("ReviewerReviews", fields: [reviewerId], references: [id])

  @@index([articleId])
  @@index([reviewerId, status])
}

// ---------------------------------------------------------------------------
// PREMIUM: Independent Review Network — free, external community/expert
// review channels (Hypothes.is annotations to start; PREreview, OpenReview,
// PCI, Sciety, and SciPost in later phases), surfaced on the public Review
// History tab as a "Community and Independent Review" section alongside the
// journal's own ("In-house") peer review above. Every row here is a REAL,
// fetched, verbatim-excerpted record pulled from the named external
// platform's own public API — nothing here is ever authored, paraphrased,
// or fabricated by this platform. sourceType distinguishes rows an
// automated sync wrote from ones an editor pasted in by hand for channels
// with no stable public read API yet (PCI, Sciety, SciPost).
// ---------------------------------------------------------------------------
model IndependentReview {
  id             String   @id @default(cuid())
  articleId      String
  channel        String // HYPOTHESIS | PREREVIEW | OPENREVIEW | PCI | SCIETY | SCIPOST
  sourceType     String   @default("AUTOMATED") // AUTOMATED | EDITOR_ENTERED
  // Channel-specific identifier (e.g. a Hypothes.is annotation id), used to
  // upsert idempotently on re-sync. Null for editor-entered links that have
  // no distinct id of their own — Postgres allows multiple NULLs under a
  // unique constraint, so this never blocks more than one manual entry.
  externalId     String?
  externalUrl    String
  // Null when the source channel doesn't disclose (or the annotation is
  // posted under) a real identity — never guessed at.
  reviewerName   String?
  // Verbatim excerpt from the source, truncated for storage — never
  // authored or summarized by this platform.
  excerpt        String?
  // Structured verdict, only populated when the channel itself provides one
  // (e.g. a PREreview rapid-review recommendation).
  recommendation String?
  postedAt       DateTime? // when the review was created on the source platform, if known
  fetchedAt      DateTime @default(now())
  createdAt      DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id])

  @@unique([articleId, channel, externalId])
  @@index([articleId, channel])
}

// Per (article, channel) bookkeeping for the on-demand sync in
// src/lib/independent-reviews.ts: when a reader opens the Review History
// tab, a sync only actually re-hits the external API if the last check for
// that article+channel is missing or older than the staleness window — this
// is what makes that cheap for popular articles instead of hitting the
// external API on every single page view.
model IndependentReviewSyncState {
  id            String   @id @default(cuid())
  articleId     String
  channel       String
  lastCheckedAt DateTime @default(now())
  lastError     String?

  @@unique([articleId, channel])
}

// ---------------------------------------------------------------------------
// Editorial decision log
// ---------------------------------------------------------------------------
model EditorialDecision {
  id        String   @id @default(cuid())
  articleId String
  editorId  String
  decision  String // ASSIGN_REVIEWERS | REQUEST_REVISIONS | ACCEPT | REJECT | SEND_TO_PRODUCTION
  note      String? // short internal note — always private, never shown to the author or public
  createdAt DateTime @default(now())

  // Optional formatted, author-facing decision letter — distinct from
  // `note` above (which stays internal-only). Only populated when an
  // editor explicitly composes one (src/app/api/articles/[id]/decision-
  // letter/route.ts); most decisions still only ever get the short
  // internal `note`. `letterPublishedAt` is set when the article's
  // reviewTransparency mode makes it part of the public Review History
  // tab — a letter can exist privately (sent to the author) before that.
  letterBody        String?
  letterPublishedAt DateTime?

  article Article @relation(fields: [articleId], references: [id])
  editor  User    @relation(fields: [editorId], references: [id])

  @@index([articleId])
}

// ---------------------------------------------------------------------------
// Author's response to reviewers — one entry per revision round, addressing
// the round's reviews together (mirrors EditorialDecision's one-row-per-
// round-event shape rather than tying to a single Review row). Feeds the
// transparent Review History tab (src/components/views/article-view.tsx)
// alongside Review.commentsToAuthor and EditorialDecision.letterBody.
// ---------------------------------------------------------------------------
model AuthorResponse {
  id        String   @id @default(cuid())
  articleId String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id])
  author  User    @relation(fields: [authorId], references: [id])

  @@index([articleId])
}

// ---------------------------------------------------------------------------
// Billing & Subscription Service (Stripe-style mock)
// ---------------------------------------------------------------------------
model Subscription {
  id               String    @id @default(cuid())
  userId           String
  plan             String // READER_MONTHLY | READER_YEARLY | INSTITUTIONAL
  status           String    @default("ACTIVE") // ACTIVE | CANCELED | PAST_DUE | TRIALING
  provider         String? // stripe | paypal | paymongo | xendit | lemonsqueezy
  stripeSubId      String? // provider's session/subscription reference (name predates multi-gateway support)
  currentPeriodEnd DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Invoice {
  id              String    @id @default(cuid())
  userId          String
  articleId       String?
  bookId          String?
  type            String // APC | SUBSCRIPTION | INSTITUTIONAL | DISTRIBUTION_PACKAGE
  amount          Float
  currency        String    @default("USD")
  status          String    @default("OPEN") // OPEN | PAID | VOID | REFUNDED
  provider        String? // stripe | paypal | paymongo | xendit | lemonsqueezy
  stripeInvoiceId String? // provider's session/charge reference (name predates multi-gateway support)
  metadata        String? // JSON — e.g. { "plan": "READER_YEARLY" } for SUBSCRIPTION invoices
  paidAt          DateTime?
  createdAt       DateTime  @default(now())

  user    User     @relation(fields: [userId], references: [id])
  article Article? @relation(fields: [articleId], references: [id])
  book    Book?    @relation(fields: [bookId], references: [id])

  @@index([userId])
  @@index([articleId])
  @@index([bookId])
}

// ---------------------------------------------------------------------------
// Notification Service
// ---------------------------------------------------------------------------
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // INFO | SUCCESS | WARNING | ERROR
  title     String
  message   String
  read      Boolean  @default(false)
  articleId String?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  article Article? @relation(fields: [articleId], references: [id])

  @@index([userId, read, createdAt])
  @@index([articleId])
}

// ---------------------------------------------------------------------------
// Audit Log (cross-service event sourcing)
// ---------------------------------------------------------------------------
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String // SUBMIT | ASSIGN_REVIEWER | SUBMIT_REVIEW | ACCEPT | REJECT | PUBLISH | DOI_MINT | DOI_PUBLISH | PAYMENT_RECEIVED | CROSSREF_DEPOSIT | GALLEY_GENERATED
  entityType String // ARTICLE | REVIEW | INVOICE | SUBSCRIPTION | USER
  entityId   String
  articleId  String?
  metadata   String? // JSON string
  createdAt  DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id])
  article Article? @relation(fields: [articleId], references: [id])

  @@index([articleId, createdAt])
  @@index([userId, createdAt])
}

// ---------------------------------------------------------------------------
// Storage Service — tracks every file in the three S3 buckets
// ---------------------------------------------------------------------------
model StorageObject {
  id                String    @id @default(cuid())
  bucket            String // raw-submissions | anonymized-manuscripts | published-galleys
  key               String    @unique
  fileName          String
  contentType       String
  sizeBytes         Int
  uploadStatus      String    @default("PENDING") // PENDING | UPLOADED | FAILED
  uploadedBy        String? // user id
  articleId         String?
  // Denormalized from the latest MalwareScanJob for this object — cheap to
  // read without a join wherever a download/publish path needs to check
  // scan status.
  malwareScanStatus String    @default("PENDING") // PENDING | SKIPPED | CLEAN | SUSPICIOUS | MALICIOUS | FAILED
  // Pre-signed URL metadata
  presignToken      String?   @unique
  presignExpiresAt  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([articleId])
}

// ---------------------------------------------------------------------------
// Galley Job — tracks Pandoc conversion jobs from the production worker
// ---------------------------------------------------------------------------
model GalleyJob {
  id           String    @id @default(cuid())
  articleId    String
  inputKey     String // storage key of source DOCX/MD
  status       String    @default("QUEUED") // QUEUED | PROCESSING | COMPLETED | FAILED
  htmlKey      String?
  pdfKey       String?
  jatsKey      String?
  epubKey      String?
  workerLog    String? // JSON-stringified worker output
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([status, createdAt])
  @@index([articleId])
}

// ---------------------------------------------------------------------------
// Integrity Check Job — tracks enterprise-tier plagiarism checks submitted
// to an external vendor (Turnitin's iThenticate API). Same durable
// atomic-claim job shape as GalleyJob (src/lib/galley-job.ts), with one
// extra state: iThenticate's real flow is submit-then-await-a-webhook,
// distinct from Pandoc's synchronous local run, so SUBMITTED (waiting on
// the vendor) needs to stay distinct from PROCESSING (this app actively
// working) for accurate status display.
// ---------------------------------------------------------------------------
model IntegrityCheckJob {
  id                   String    @id @default(cuid())
  articleId            String
  provider             String    @default("ITHENTICATE")
  inputKey             String // storage key of the manuscript submitted for the check
  status               String    @default("QUEUED") // QUEUED | SUBMITTED | PROCESSING | COMPLETED | FAILED
  mode                 String    @default("simulation") // "live" | "simulation" — which path produced this job's result
  externalSubmissionId String?
  reportUrl            String?
  similarityScore      Float?
  matchBreakdown       String? // JSON
  workerLog            String?
  errorMessage         String?
  startedAt            DateTime?
  completedAt          DateTime?
  createdAt            DateTime  @default(now())

  @@index([status, createdAt])
  @@index([articleId])
}

// ---------------------------------------------------------------------------
// Malware Scan Job — every uploaded file is scanned via VirusTotal
// (src/lib/virustotal.ts), free tier, no code changes needed to go live
// beyond setting VIRUSTOTAL_API_KEY. Unlike IntegrityCheckJob's vendor
// webhook, VirusTotal's free public API has no webhook — completion is
// discovered by polling GET /analyses/{id}, so SUBMITTED jobs are
// deliberately re-included (not excluded, unlike IntegrityCheckJob) by the
// cron sweep: polling is a read with no side effects, so re-checking a
// SUBMITTED job is always safe, never a duplicate paid submission.
// ---------------------------------------------------------------------------
model MalwareScanJob {
  id                 String    @id @default(cuid())
  storageObjectId    String
  bucket             String
  inputKey           String // storage key of the file being scanned
  status             String    @default("QUEUED") // QUEUED | PROCESSING | SUBMITTED | COMPLETED | FAILED
  mode               String    @default("simulation") // "live" | "simulation" — which path produced this job's result
  externalAnalysisId String?
  verdict            String? // CLEAN | SUSPICIOUS | MALICIOUS — null until COMPLETED
  maliciousCount     Int?
  suspiciousCount    Int?
  reportUrl          String?
  workerLog          String?
  errorMessage       String?
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime  @default(now())

  @@index([status, createdAt])
  @@index([storageObjectId])
}

// ---------------------------------------------------------------------------
// Alt-Text Job — AI-generated figure alt text (src/lib/alt-text.ts), for
// accessibility compliance. Figures live inline as <img> tags inside the
// galley HTML blob (no first-class Figure model exists), so this job
// parses them out, generates a suggestion per image, and stores results
// for editor review rather than auto-rewriting the live galley — a
// separate explicit "apply" action commits reviewed suggestions into the
// galley HTML. Same durable atomic-claim shape as GalleyJob.
// ---------------------------------------------------------------------------
model AltTextJob {
  id              String    @id @default(cuid())
  articleId       String
  status          String    @default("QUEUED") // QUEUED | PROCESSING | COMPLETED | FAILED
  imagesFound     Int       @default(0)
  imagesProcessed Int       @default(0)
  results         String? // JSON: [{src, existingAlt, suggestedAlt, mode}]
  appliedAt       DateTime? // set once an editor applies results to the galley HTML
  workerLog       String?
  errorMessage    String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())

  @@index([status, createdAt])
  @@index([articleId])
}

// Table counterpart to AltTextJob — AI-generated accessibility captions
// for <table> elements in an article's galley HTML (src/lib/
// table-accessibility.ts), same durable atomic-claim shape and same
// "suggestions stored for editor review, never auto-applied" contract.
model TableAccessibilityJob {
  id              String    @id @default(cuid())
  articleId       String
  status          String    @default("QUEUED") // QUEUED | PROCESSING | COMPLETED | FAILED
  tablesFound     Int       @default(0)
  tablesProcessed Int       @default(0)
  results         String? // JSON: [{index, existingCaption, suggestedCaption, mode}]
  appliedAt       DateTime? // set once an editor applies results to the galley HTML
  errorMessage    String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())

  @@index([status, createdAt])
  @@index([articleId])
}

// ---------------------------------------------------------------------------
// Table/dataset extraction — the "AI & checks" tab's structured-data
// counterpart to TableAccessibilityJob's captions (src/lib/
// table-extraction.ts). Deliberately no Prisma relation to Article, just a
// loose articleId String — same convention as AltTextJob/
// TableAccessibilityJob above.
// ---------------------------------------------------------------------------
model TableExtractionJob {
  id              String    @id @default(cuid())
  articleId       String
  status          String    @default("QUEUED") // QUEUED | PROCESSING | COMPLETED | FAILED
  tablesFound     Int       @default(0)
  tablesProcessed Int       @default(0)
  results         String? // JSON: [{index, columns, rows, notes, notesMode}]
  errorMessage    String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())

  @@index([status, createdAt])
  @@index([articleId])
}

// ---------------------------------------------------------------------------
// Eleventh Research Lab — dashboard tab for author/expert/reviewer/editor/
// admin accounts (src/components/dashboard/research-lab-tab.tsx). Both
// models deliberately have no Prisma relation to User, just a loose
// userId String — same convention as AltTextJob/TableAccessibilityJob's
// loose articleId above.
// ---------------------------------------------------------------------------

// A saved output from the Research Gap Finder or the Systematic Review /
// PRISMA drafting tool (src/lib/research-gap-finder.ts,
// src/lib/prisma-draft.ts). Only ever written on a real LLM success — same
// cache-but-only-on-success convention as ArticleSimilarityExplanation —
// so a run that came back "unavailable" (no LLM configured) never shows up
// as false history.
model ResearchLabDocument {
  id         String   @id @default(cuid())
  userId     String
  kind       String // "GAP_ANALYSIS" | "PRISMA_DRAFT"
  title      String
  inputJson  String // JSON: the sources/article ids this was generated from
  resultJson String // JSON: the gaps[] or draft text
  model      String?
  createdAt  DateTime @default(now())

  @@index([userId, kind, createdAt])
}

// Qualitative-data transcription job (src/lib/transcription.ts) — runs a
// real, free, open-source Whisper model locally via @xenova/transformers
// over a researcher-uploaded WAV file. No heuristic fallback exists for
// "guess what audio says", so an unusable result is a FAILED job with a
// real errorMessage, never a fabricated transcript.
model TranscriptionJob {
  id           String    @id @default(cuid())
  userId       String
  audioKey     String
  fileName     String
  status       String    @default("QUEUED") // QUEUED | PROCESSING | COMPLETED | FAILED
  transcript   String?
  model        String?
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId, createdAt])
}

// ---------------------------------------------------------------------------
// NarrationJob — "auto-narrate" a published Article/MagazinePiece/MediaPost
// into a real downloadable audio file using Kokoro-82M (src/lib/kokoro-tts.ts),
// a real, free, open-weight TTS model run locally via @huggingface/transformers
// (through the kokoro-js wrapper) — no external API, no per-request cost, same
// "run the real open model in-process, fail open if it can't load" pattern as
// TranscriptionJob/ArticleEmbedding above. Polymorphic target reference
// (contentType/contentId, no FK) mirrors AuditLog's entityType/entityId —
// deliberately not a relation, since the target spans three unrelated models.
model NarrationJob {
  id           String    @id @default(cuid())
  contentType  String // ARTICLE | MAGAZINE_PIECE | MEDIA_POST
  contentId    String
  status       String    @default("QUEUED") // QUEUED | PROCESSING | COMPLETED | FAILED
  voice        String    @default("af_heart") // Kokoro voice id, see src/lib/kokoro-tts.ts
  audioKey     String?
  durationSec  Int?
  wordCount    Int?
  model        String?
  workerLog    String?
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  createdBy User @relation(fields: [createdById], references: [id])

  // One row per (content item, persona) — lets a reader-facing "Listen"
  // section offer more than one real generated narration (e.g. a male and a
  // female Kokoro voice) for the same article instead of only ever one.
  @@unique([contentType, contentId, voice])
  @@index([contentType, contentId])
  @@index([status, createdAt])
}

// ---------------------------------------------------------------------------
// Retraction Watch Database — a local mirror of Crossref's real, free,
// publicly-hosted CSV of the Retraction Watch database
// (https://gitlab.com/crossref/retraction-watch-data, no API key required)
// so a cited reference's DOI (Reference.doi, already resolved via OpenAlex)
// can be checked against actual retractions with a fast indexed local
// lookup instead of an external call per reference. See
// src/lib/retraction-watch.ts for the sync job and honesty contract: an
// unsynced table returns "not yet checked", never a false "nothing found".
// ---------------------------------------------------------------------------
model RetractionWatchRecord {
  id               String    @id @default(cuid())
  originalPaperDoi String    @unique
  originalTitle    String?
  journal          String?
  retractionDoi    String?
  retractionDate   DateTime?
  reason           String? // semicolon-separated, verbatim from the source dataset
  syncedAt         DateTime  @default(now())

  @@index([originalPaperDoi])
}

/// Singleton (always id "singleton") tracking the last sync attempt, so
/// "0 retracted references found" can be told apart from "never synced" —
/// see src/lib/retraction-watch.ts.
model RetractionWatchSyncMeta {
  id           String    @id @default("singleton")
  lastSyncedAt DateTime?
  recordCount  Int       @default(0)
  lastError    String?
}

// ---------------------------------------------------------------------------
// Preservation Deposit — dark-archive preservation status with CLOCKSS /
// Portico (src/lib/preservation.ts). Neither service exposes a public
// per-article API — they harvest bulk content (via OAI-PMH, among other
// mechanisms) under a signed institutional agreement, or crawl under a
// published LOCKSS permission statement — so unlike GalleyJob/
// IntegrityCheckJob/AltTextJob above, this is deliberately NOT a job
// model: there is no automatable submit-and-poll flow to run. It's
// self-reported, admin-maintained status, the same shape Distribution/
// BookDistribution already use for other no-public-API integrations.
// Journal-granularity, not per-article: both services cover a journal's
// full run under one standing agreement.
// ---------------------------------------------------------------------------
model PreservationDeposit {
  id              String    @id @default(cuid())
  journalId       String
  provider        String // CLOCKSS | PORTICO
  status          String    @default("NOT_STARTED") // NOT_STARTED | AGREEMENT_PENDING | HARVESTING_ENABLED | CONFIRMED_ARCHIVED | LAPSED
  agreementRef    String? // self-reported contract/agreement identifier
  coverageFrom    DateTime? // earliest confirmed-archived content date
  lastConfirmedAt DateTime?
  notes           String?
  updatedBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([journalId, provider])
  @@index([journalId])
}

// Manual-application directory listings (ROAD, ISI, ResearchBib,
// Citefactor, SAJI Journal Index, and similar). None of these expose a
// public submission API — a journal applies once, a human reviews it, and
// only then does a listing appear — so like PreservationDeposit above,
// this is a self-reported, admin-maintained record, not a live
// integration. See src/lib/directory-listings.ts.
model DirectoryListing {
  id         String    @id @default(cuid())
  journalId  String
  directory  String // ROAD | ISI | RESEARCHBIB | CITEFACTOR | SAJI
  status     String    @default("NOT_APPLIED") // NOT_APPLIED | APPLIED | UNDER_REVIEW | INDEXED | REJECTED
  appliedAt  DateTime?
  listingUrl String? // the directory's own page for this journal, once indexed
  notes      String?
  updatedBy  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([journalId, directory])
  @@index([journalId])
}

// ---------------------------------------------------------------------------
// Certificate — recognition/membership/affiliation documents for authors,
// reviewers, and editors (see src/lib/certificates.ts). Each row is a
// permanent, immutable record of one issued certificate: the exact content
// rendered into the PDF is captured at issuance (recipientName, category,
// issuedAt) so a re-fetch of this row always reproduces the same
// contentHash — the basis for the public /verify/[serialNumber] page, which
// recomputes the hash from these stored fields and confirms it matches
// what's printed on the certificate. Cryptographically verifiable and
// tamper-evident (any alteration after issuance breaks the hash match);
// deliberately NOT described as "blockchain" anywhere in the UI, since
// verification here depends on this platform's own database rather than a
// decentralized ledger — see the corresponding conversation for why a real
// blockchain-anchoring path (OpenTimestamps) was evaluated and dropped: the
// only maintained npm client has a reproducible serialize/deserialize bug
// that breaks reading back a saved proof, even via its own official CLI.
// ---------------------------------------------------------------------------
model Certificate {
  id            String  @id @default(cuid())
  userId        String
  type          String // RECOGNITION | MEMBERSHIP | AFFILIATION
  category      String // AUTHOR | REVIEWER | EDITOR — the capacity the certificate is issued for
  recipientName String // snapshot at issuance, independent of later profile edits
  journalName   String // snapshot at issuance — the hash must be reproducible from this
  issn          String? // snapshot at issuance
  workTitle     String? // exact title of the article/book cited (AUTHOR category), snapshot at issuance
  serialNumber  String  @unique
  contentHash   String  @unique // sha256 of the canonical certificate payload
  pdfKey        String // storage key of the rendered PDF

  // Which src/lib/certificate-pdf.ts template rendered this row's PDF —
  // compared against CURRENT_CERTIFICATE_TEMPLATE_VERSION in
  // src/lib/certificates.ts so GET /api/certificates can auto-heal any
  // certificate rendered under an older layout, independent of whether
  // journalName/issn/workTitle themselves changed. Existing rows default
  // to 0, older than any real version, so a version bump alone is enough
  // to trigger a one-time re-render of every previously issued certificate.
  templateVersion Int @default(0)

  issuedAt  DateTime @default(now())
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([serialNumber])
}

// ---------------------------------------------------------------------------
// Distribution — per-article syndication tracking to external platforms
// (see src/lib/distribution.ts). One row per (articleId, platform) pair,
// created on demand when an author/editor first generates a share package
// for that platform. Tier reflects how much of the submission can actually
// be automated for that platform today:
//   A = real API publish (e.g. Blogger)
//   B = generated submission package + prefilled metadata, human clicks submit
//   C = no public API — generated "share kit" text only, completion is
//       self-reported by whoever posted it manually
// PUBLISHED articles only — distribution of unpublished work is out of scope.
model Distribution {
  id        String @id @default(cuid())
  articleId String
  platform  String // RESEARCHGATE | ACADEMIA_EDU | SUBSTACK | MEDIUM | LINKEDIN | HUBPAGES | ...
  tier      String // A | B | C

  status         String  @default("NOT_STARTED") // NOT_STARTED | PACKAGE_READY | AWAITING_AUTHOR_ACTION | SUBMITTED | LIVE | FAILED
  packageContent String? // generated share-kit text (blurb + excerpt + canonical link) for Tier C/B
  packageKey     String? // storage key for a generated binary package (Tier B PDFs etc.), when applicable
  externalUrl    String?
  externalId     String?

  authorConsent Boolean   @default(false)
  consentedAt   DateTime?
  submittedBy   String?
  submittedAt   DateTime?
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  article   Article @relation(fields: [articleId], references: [id])
  submitter User?   @relation(fields: [submittedBy], references: [id])

  @@unique([articleId, platform])
  @@index([articleId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Book publishing — a second, distinct content type alongside journal
// articles. A Book is either a MONOGRAPH (single uploaded manuscript, its
// own author submission) or an EDITED_VOLUME/ANTHOLOGY (compiled from
// existing PUBLISHED articles via BookArticle, e.g. a "Best of Volume N"
// collection) — the format determines which production path
// src/lib/book-production.ts takes, not a separate model.
// ---------------------------------------------------------------------------
model Book {
  id          String  @id @default(cuid())
  title       String
  subtitle    String?
  authors     String // JSON array of {name, affiliation, orcid, email} — same shape as Article.authors
  description String
  category    String // e.g. Physics, Education, Multidisciplinary — free text, mirrors Article.discipline
  format      String // MONOGRAPH | EDITED_VOLUME | ANTHOLOGY
  isbn        String?
  price       Float?  @default(0)

  correspondingAuthorId String?

  coverImageKey String?
  manuscriptKey String? // MONOGRAPH only — source manuscript for production
  epubKey       String? // published EPUB
  pdfKey        String? // published print-ready PDF

  // Workflow state machine — deliberately mirrors Article.status so the
  // same editorial mental model (and AuditLog action vocabulary) applies:
  // SUBMITTED | UNDER_REVIEW | ACCEPTED | IN_PRODUCTION | PUBLISHED | REJECTED
  status String @default("SUBMITTED")

  submittedAt DateTime  @default(now())
  acceptedAt  DateTime?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Paid Distribution Package (revenue Phase 6) — unlocks Tier B
  // (Draft2Digital/IngramSpark) distribution package generation. Tier C
  // (Amazon KDP/Lulu) share kits stay free.
  distributionPackagePaidAt DateTime?

  // Author's share of net royalties from aggregator sales (Draft2Digital/
  // IngramSpark), as a percentage — set at acceptance, editable by staff.
  // Snapshotted onto each RoyaltyStatement at recording time so a later
  // change to this default never rewrites a past statement's numbers.
  royaltySharePercent Float? @default(70)

  author            User?              @relation(fields: [correspondingAuthorId], references: [id])
  chapters          BookArticle[]
  distributions     BookDistribution[]
  royaltyStatements RoyaltyStatement[]
  invoices          Invoice[]

  @@index([status, submittedAt])
  @@index([correspondingAuthorId])
}

// Self-reported royalty statements for book sales through the aggregator
// accounts (Draft2Digital/IngramSpark/Amazon KDP/Lulu). EPIP has no API
// access to these platforms' actual sales/royalty reporting (a much deeper
// integration than the submission flow built in Phase 4), so this is staff
// manually transcribing figures from each platform's own dashboard — same
// honesty pattern as Distribution/BookDistribution's self-reported LIVE
// status. One row per reporting period per platform (or "ALL" if a staff
// member is recording a combined total rather than a per-platform figure).
model RoyaltyStatement {
  id          String   @id @default(cuid())
  bookId      String
  platform    String // DRAFT2DIGITAL | INGRAMSPARK | AMAZON_KDP | LULU | ALL
  periodStart DateTime
  periodEnd   DateTime

  unitsSold    Int   @default(0)
  grossRevenue Float @default(0)

  // Snapshot of Book.royaltySharePercent at the time this statement was
  // recorded, and the computed payout — both stored (not recomputed live)
  // so a later change to the book's royalty terms never rewrites history.
  royaltySharePercent Float
  authorPayout        Float

  notes      String?
  recordedBy String
  recordedAt DateTime @default(now())

  book     Book @relation(fields: [bookId], references: [id])
  recorder User @relation(fields: [recordedBy], references: [id])

  @@index([bookId])
}

// Book distribution — the KDP/B&N/IngramSpark/Apple Books/Lulu/Draft2Digital/
// Smashwords tier from the syndication plan. Draft2Digital and IngramSpark
// are themselves aggregators (D2D alone reaches Apple Books, B&N, Kobo, and
// Smashwords's storefront from one submission; IngramSpark covers print +
// wide ebook distribution), so those two are Tier B (real submission flow,
// prefilled package, human clicks submit — same treatment as arXiv/SSRN in
// Distribution). Amazon KDP and Lulu have no public third-party publish API,
// so they're Tier C (share-kit/manual, self-reported), same shape as
// Distribution's ResearchGate/Academia.edu tier. Mirrors Distribution's
// columns exactly for the same reasons (see that model's comments).
model BookDistribution {
  id       String @id @default(cuid())
  bookId   String
  platform String // DRAFT2DIGITAL | INGRAMSPARK | AMAZON_KDP | LULU
  tier     String // B | C

  status         String  @default("NOT_STARTED") // NOT_STARTED | PACKAGE_READY | SUBMITTED | LIVE | FAILED
  packageContent String? // generated metadata package JSON
  externalUrl    String?
  externalId     String? // ASIN / platform title id, once live

  authorConsent Boolean   @default(false)
  consentedAt   DateTime?
  submittedBy   String?
  submittedAt   DateTime?
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  book      Book  @relation(fields: [bookId], references: [id])
  submitter User? @relation(fields: [submittedBy], references: [id])

  @@unique([bookId, platform])
  @@index([bookId])
  @@index([status])
}

// Join table compiling existing PUBLISHED articles into an
// EDITED_VOLUME/ANTHOLOGY Book, in reader order.
model BookArticle {
  id           String @id @default(cuid())
  bookId       String
  articleId    String
  chapterOrder Int    @default(0)

  createdAt DateTime @default(now())

  book    Book    @relation(fields: [bookId], references: [id])
  article Article @relation(fields: [articleId], references: [id])

  @@unique([bookId, articleId])
  @@index([bookId, chapterOrder])
}

// Editor-curated thematic bundle of already-PUBLISHED articles — a
// "Special Issue" or "Collection" landing page, distinct from a Book
// (no production pipeline, no DOI of its own, no distribution tiers) and
// distinct from an Issue (an Issue is the journal's actual sequential
// numbering; a Collection is a cross-cutting theme that can pull articles
// from any issue). Direct reuse of the BookArticle join-table pattern.
model Collection {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  description   String
  coverImageKey String?
  createdById   String
  createdAt     DateTime  @default(now())
  // Null while an editor is still assembling it — only publishedAt-set
  // collections are ever returned by the public GET /api/collections.
  publishedAt   DateTime?

  createdBy User                @relation(fields: [createdById], references: [id])
  articles  CollectionArticle[]
}

model CollectionArticle {
  id           String @id @default(cuid())
  collectionId String
  articleId    String
  order        Int    @default(0)

  createdAt DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  article    Article    @relation(fields: [articleId], references: [id])

  @@unique([collectionId, articleId])
  @@index([collectionId, order])
}

// Durable production queue for Book EPUB/PDF generation — same
// atomic-claim pattern as GalleyJob (see src/lib/book-production.ts,
// mirroring src/lib/galley-job.ts).
model BookProductionJob {
  id           String    @id @default(cuid())
  bookId       String
  status       String    @default("QUEUED") // QUEUED | PROCESSING | COMPLETED | FAILED
  epubKey      String?
  pdfKey       String?
  workerLog    String?
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([status, createdAt])
  @@index([bookId])
}

// ---------------------------------------------------------------------------
// COUNTER 5 Usage Events — raw event log for SUSHI-compatible reporting
// ---------------------------------------------------------------------------
model CounterEvent {
  id            String   @id @default(cuid())
  articleId     String?
  userId        String?
  // Metric_Type: Total_Item_Investigations | Total_Item_Requests | Unique_Item_Investigations | Unique_Item_Requests
  metricType    String
  // Access_Method: Regular | TDM
  accessMethod  String   @default("Regular")
  // Access_Type: OA | Controlled
  accessType    String   @default("OA")
  // Section_Type: Article | Search|TOC | Publication
  sectionType   String   @default("Article")
  // YOP = Year of Publication
  yop           Int?
  // Identifier
  doi           String?
  isbn          String?
  issn          String?
  // Requesting institution (for institutional subscribers)
  institutionId String?
  // Session/user fingerprint for unique deduplication
  sessionId     String?
  userAgent     String?
  ipAddress     String?
  createdAt     DateTime @default(now())

  @@index([articleId, createdAt])
  @@index([metricType, createdAt])
}

// ---------------------------------------------------------------------------
// PREMIUM: Institutional IP Authentication
// ---------------------------------------------------------------------------
model Institution {
  id                String    @id @default(cuid())
  name              String
  domain            String? // e.g. "harvard.edu"
  country           String?
  // Research Organization Registry ID (e.g. "01an7q238") — the persistent
  // institutional identifier now expected by Crossref/DataCite/ORCID
  // metadata in place of free-text affiliation strings.
  rorId             String?
  // IP ranges in CIDR notation, comma-separated (e.g. "128.103.0.0/16,140.247.0.0/16")
  ipRanges          String
  // SSO / Shibboleth entity ID (optional)
  ssoEntityId       String?
  ssoMetadataUrl    String?
  // Subscription details
  plan              String    @default("INSTITUTIONAL") // INSTITUTIONAL | TRANSFORMATIVE
  status            String    @default("ACTIVE") // ACTIVE | EXPIRED | TRIALING
  currentPeriodEnd  DateTime?
  // Transformative agreement: APC quota for authors from this institution
  apcQuota          Int       @default(0)
  apcUsed           Int       @default(0)
  // COUNTER 5 customer ID for SUSHI report slicing
  counterCustomerId String?
  // Per-institution SUSHI API key — required to retrieve THIS institution's
  // usage report (customer_id + api_key), so one institution's librarian
  // can't read another's usage data by guessing a customer_id. Auto-
  // generated on institution creation (src/lib/institutions.ts,
  // generateCounterApiKey()); SUPER_ADMIN can view/regenerate it.
  // Not @unique: `prisma db push` refuses a new unique constraint without
  // --accept-data-loss once the table has rows (even though NULLs are
  // distinct under Postgres UNIQUE, so no real collision risk exists here);
  // 192 bits of randomBytes(24) entropy already makes a real collision
  // negligible without a DB-level constraint backing it up.
  counterApiKey     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  users    User[]
  datasets DatasetLink[]
}

// ---------------------------------------------------------------------------
// PREMIUM: Zenodo / OSF / Dryad Data Deposit Integration
// ---------------------------------------------------------------------------
model DatasetLink {
  id              String   @id @default(cuid())
  articleId       String
  repository      String // ZENODO | OSF | DRYAD | FIGSHARE | GITHUB
  datasetDoi      String? // e.g. 10.5281/zenodo.1234567
  datasetUrl      String
  datasetTitle    String
  depositorId     String
  // Relation type per Crossref: isSupplementedBy | isReferencedBy | isSourceOf
  relationType    String   @default("isSupplementedBy")
  // Zenodo deposit metadata
  zenodoDepositId String?
  zenodoConceptId String?
  createdAt       DateTime @default(now())

  article       Article      @relation(fields: [articleId], references: [id])
  institution   Institution? @relation(fields: [institutionId], references: [id])
  institutionId String?

  @@index([articleId])
}

// ---------------------------------------------------------------------------
// PREMIUM: Semantic Search Embeddings
// ---------------------------------------------------------------------------
model ArticleEmbedding {
  id         String   @id @default(cuid())
  articleId  String   @unique
  // Embedding vector stored as a JSON-stringified array of floats — the
  // canonical store and automatic fallback source. Generated by a real,
  // free, open-source local sentence-embedding model
  // (Xenova/all-MiniLM-L6-v2 via @xenova/transformers, src/lib/
  // embeddings.ts) when it can load in this instance; falls back to a
  // deterministic 384-dim hashed n-gram scheme (hashEmbedding()) at the
  // same dimensionality otherwise, so the two are never compared against
  // each other. `model` records which one actually produced this row —
  // "hashed-ngram-v1" for the fallback, the real model id otherwise.
  //
  // A parallel `vec` Postgres schema (native pgvector column + HNSW index,
  // see src/lib/pgvector.ts) exists alongside this table for indexed
  // similarity search at scale, but is deliberately NOT modeled here in
  // Prisma — `prisma db push` diffs the entire namespace it connects to,
  // so any Prisma-declared object sharing a namespace with a raw-SQL-
  // created one risks being flagged as drift and dropped on a later
  // deploy. Keep pgvector objects out of schema.prisma entirely.
  embedding  String // JSON stringified float array
  model      String   @default("hashed-ngram-v1")
  textHash   String // SHA-256 of the embedded text (for cache invalidation)
  dimensions Int      @default(384)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  article Article @relation(fields: [articleId], references: [id])
}

// ---------------------------------------------------------------------------
// RAG: per-article passage chunks for the "Ask this paper" chat feature
// (src/lib/chunk-embeddings.ts). Distinct from ArticleEmbedding above —
// that one embeds title+abstract+keywords for cross-corpus similarity/
// search; this one embeds ~800-character passages of the article's own
// full galley text so a chat question can be answered from the specific
// paragraph that's actually relevant, not just the abstract.
// ---------------------------------------------------------------------------
model ArticleChunk {
  id         String @id @default(cuid())
  articleId  String
  chunkIndex Int
  text       String

  // Canonical store — JSON-stringified float array, same dual-write
  // pattern as ArticleEmbedding: written unconditionally here; the
  // optional vec.article_chunk_embedding pgvector table (src/lib/
  // pgvector.ts) is a pure opportunistic upgrade for indexed retrieval,
  // same fail-open design, deliberately kept out of this schema for the
  // same drift-on-`db push` reason documented on ArticleEmbedding above.
  embedding     String
  embeddingDims Int
  // "local-model" when the real open-source sentence embedding model
  // (@xenova/transformers, all-MiniLM-L6-v2) loaded and ran successfully;
  // "hash-fallback" when it wasn't available (no network to the model
  // CDN, cold-start budget exceeded, etc.) and the same deterministic
  // n-gram hash used by ArticleEmbedding ran instead. Retrieval only
  // compares embeddings written in the same mode — see retrieveChunks()
  // — so this is never silently presented as higher-quality than it is.
  embeddingMode String

  createdAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, chunkIndex])
  @@index([articleId])
}

// Full-text (not just abstract) translation of an article's galley body
// into one of the site's non-English locales — src/lib/galley-translation.ts.
// Kept in its own table rather than a JSON column on Article (unlike
// Article.abstractTranslations, which is short enough for that) since a
// full article's translated text, across several locales, would otherwise
// bloat every Article row read regardless of whether a translation was
// ever requested.
model ArticleGalleyTranslation {
  id             String   @id @default(cuid())
  articleId      String
  locale         String
  translatedText String
  mode           String // "llm" | "partial" | "heuristic" — see galley-translation.ts
  model          String
  translatedAt   DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, locale])
  @@index([articleId])
}

// Caches a short AI-generated explanation of why `relatedArticleId` was
// recommended alongside `articleId` (src/lib/related-explanation.ts) — the
// pair itself comes from real embedding similarity (getSimilarArticles in
// manuscript-checks.ts), this just explains it in a sentence a reader can
// understand. Cached per pair since the (articleId, relatedArticleId)
// similarity ranking is deterministic for a given corpus snapshot, and
// reused by both the article page's "Continue reading" and the logged-in
// reader's "Recommended for you" digest (src/lib/recommendations.ts) — no
// need to regenerate the same explanation for both surfaces. No heuristic
// fallback: a plausible-sounding but wrong reason is actively misleading
// (same reasoning as GlossaryResult) — mode: "unavailable" when no LLM
// tier answered, never a fabricated explanation.
model ArticleSimilarityExplanation {
  id               String   @id @default(cuid())
  articleId        String
  relatedArticleId String
  explanation      String
  mode             String // "llm" | "unavailable"
  model            String
  generatedAt      DateTime @default(now())

  article        Article @relation("SimilarityExplanationSource", fields: [articleId], references: [id], onDelete: Cascade)
  relatedArticle Article @relation("SimilarityExplanationTarget", fields: [relatedArticleId], references: [id], onDelete: Cascade)

  @@unique([articleId, relatedArticleId])
  @@index([articleId])
}

// Per-reader view history — feeds the "Recommended for you" digest
// (src/lib/recommendations.ts). Logged-in readers only (an anonymous
// visitor has no durable identity to key this on); upserted, not
// inserted, on every article view so re-reading bumps viewedAt rather
// than accumulating duplicate rows.
model ReadingHistory {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  viewedAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([userId, viewedAt])
}

// ---------------------------------------------------------------------------
// PREMIUM: LLM-Assisted Editorial Triage Report
// ---------------------------------------------------------------------------
model EditorialTriageReport {
  id                     String   @id @default(cuid())
  articleId              String   @unique
  // Scope fit score 0-100
  scopeFitScore          Int
  scopeFitReason         String
  // Methodological flags
  methodologyFlags       String // JSON array of {flag, severity, explanation}
  // Suggested reviewers (JSON array of {userId, name, matchScore, reason})
  suggestedReviewers     String
  // Recommended review model
  recommendedReviewModel String
  // 3-sentence summary
  summary                String
  // Predicted impact (1-5 stars)
  predictedImpact        Int
  // Risk flags (plagiarism risk, ethics concerns, novelty)
  riskFlags              String // JSON array
  // Full LLM response (for audit)
  rawResponse            String
  model                  String   @default("glm-4")
  createdAt              DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id])
}

// ---------------------------------------------------------------------------
// Publications: Magazines, Podcasts, Media (News/Blogs)
//
// Deliberately NOT built on top of Article. Article's shape (DOI, double-
// blind peer review state machine, plagiarism/ithenticate checks, Crossref/
// Zenodo deposit) is scholarly-manuscript-specific; magazines, podcasts, and
// news/blog posts are editorially originated (staff-written/produced, no
// external peer review), so reusing Article would mean either dragging that
// machinery along unused or littering it with nullable-only-for-some-rows
// fields. Each gets its own minimal model instead — same principle already
// applied by Book vs Article vs Collection in this schema.
// ---------------------------------------------------------------------------

// A magazine title (e.g. "Eleventh Press Review"). Issues are the
// publishing unit underneath it, same shape as Journal -> Issue above.
model Magazine {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String
  coverImageKey String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  issues MagazineIssue[]
}

// One issue of a magazine — the compiled, distributable unit (mirrors Book:
// pieces are assembled, then compiled to EPUB/PDF via a production job,
// then distributed). Editorial-only workflow (no external submission/
// acceptance step) since every piece is staff-assigned: DRAFT (assembling
// pieces) -> IN_PRODUCTION (compiling) -> PUBLISHED.
model MagazineIssue {
  id            String  @id @default(cuid())
  magazineId    String
  volume        Int
  issueNumber   Int
  year          Int
  title         String?
  theme         String?
  coverImageKey String?
  epubKey       String? // compiled EPUB, produced by MagazineIssueProductionJob
  pdfKey        String? // compiled print-ready PDF

  status      String    @default("DRAFT") // DRAFT | IN_PRODUCTION | PUBLISHED
  publishedAt DateTime?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  magazine       Magazine                     @relation(fields: [magazineId], references: [id])
  createdBy      User                         @relation(fields: [createdById], references: [id])
  pieces         MagazinePiece[]
  productionJobs MagazineIssueProductionJob[]
  distributions  MagazineDistribution[]

  @@unique([magazineId, volume, issueNumber])
  @@index([magazineId, year, volume, issueNumber])
  @@index([status, publishedAt])
}

// One piece (article/feature/interview) within an issue, in reader order.
model MagazinePiece {
  id           String   @id @default(cuid())
  issueId      String
  title        String
  dek          String? // standfirst/subheadline
  authors      String // JSON array of {name, affiliation?}
  category     String // Feature | News | Opinion | Interview | Culture — free text
  bodyHtml     String
  heroImageKey String?
  isCoverStory Boolean  @default(false)
  order        Int      @default(0)
  views        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  issue MagazineIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId, order])
}

// Durable production queue for compiling an issue's pieces into EPUB/PDF —
// same atomic-claim pattern as BookProductionJob/GalleyJob.
model MagazineIssueProductionJob {
  id           String    @id @default(cuid())
  issueId      String
  status       String    @default("QUEUED") // QUEUED | PROCESSING | COMPLETED | FAILED
  epubKey      String?
  pdfKey       String?
  workerLog    String?
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  issue MagazineIssue @relation(fields: [issueId], references: [id])

  @@index([status, createdAt])
  @@index([issueId])
}

// Self-reported distribution tracking for a published issue — same shape
// and same honesty pattern as BookDistribution (no live submission API
// exists for any of these platforms; a human still finishes the submission
// on the platform's own site, this just tracks it).
model MagazineDistribution {
  id       String @id @default(cuid())
  issueId  String
  platform String // APPLE_NEWS | FLIPBOARD | ISSUU | PRESSREADER
  tier     String // B | C

  status         String  @default("NOT_STARTED") // NOT_STARTED | PACKAGE_READY | SUBMITTED | LIVE | FAILED
  packageContent String? // generated metadata package JSON
  externalUrl    String?
  externalId     String?

  authorConsent Boolean   @default(false)
  consentedAt   DateTime?
  submittedBy   String?
  submittedAt   DateTime?
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issue     MagazineIssue @relation(fields: [issueId], references: [id])
  submitter User?         @relation(fields: [submittedBy], references: [id])

  @@unique([issueId, platform])
  @@index([issueId])
  @@index([status])
}

// A podcast show. Unlike Magazine/Book, an episode is a single uploaded
// audio file rather than a multi-piece compiled document, so there's no
// equivalent of a production-job queue here — the "compile" step doesn't
// exist. The real deliverable is the RSS 2.0 + iTunes-namespace feed
// (src/lib/podcast-rss.ts), which plays the role ONIX plays for Book.
model Podcast {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  description   String
  coverImageKey String?
  hosts         String // JSON array of {name, bio?}
  category      String // e.g. Research Culture, Science Communication — free text
  language      String   @default("eng") // ISO 639-2/B, mirrors src/lib/onix.ts's ONIX_LANGUAGE_CODE convention
  explicit      Boolean  @default(false)
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  createdBy     User                  @relation(fields: [createdById], references: [id])
  episodes      PodcastEpisode[]
  distributions PodcastDistribution[]
}

model PodcastEpisode {
  id            String  @id @default(cuid())
  podcastId     String
  seasonNumber  Int?
  episodeNumber Int
  title         String
  description   String
  guests        String? // JSON array of {name, affiliation?}
  audioKey      String? // uploaded audio file — no episode without one
  durationSec   Int? // staff-entered; no server-side audio parsing available to auto-detect it
  transcript    String?

  status      String    @default("DRAFT") // DRAFT | PUBLISHED
  publishedAt DateTime?
  createdById String
  views       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  podcast   Podcast @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id])

  @@unique([podcastId, seasonNumber, episodeNumber])
  @@index([podcastId, status, publishedAt])
}

// Self-reported distribution tracking, same shape/pattern as
// BookDistribution/MagazineDistribution. Every major podcast directory
// (Apple Podcasts Connect, Spotify for Podcasters, Amazon Music, YouTube
// Music) is fed by submitting the show's RSS feed URL through that
// platform's own onboarding form — there is no bulk publish API — so the
// "package" here is really just the validated feed URL plus prefilled show
// metadata for that form.
model PodcastDistribution {
  id        String @id @default(cuid())
  podcastId String
  platform  String // APPLE_PODCASTS | SPOTIFY | AMAZON_MUSIC | YOUTUBE_MUSIC
  tier      String // B

  status         String  @default("NOT_STARTED")
  packageContent String?
  externalUrl    String?
  externalId     String?

  authorConsent Boolean   @default(false)
  consentedAt   DateTime?
  submittedBy   String?
  submittedAt   DateTime?
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  podcast   Podcast @relation(fields: [podcastId], references: [id])
  submitter User?   @relation(fields: [submittedBy], references: [id])

  @@unique([podcastId, platform])
  @@index([podcastId])
  @@index([status])
}

// News/blog posts — the lightest of the three: no production job, no
// distribution tiers, no issue/episode grouping. A single editorial post.
model MediaPost {
  id           String  @id @default(cuid())
  type         String // NEWS | BLOG
  title        String
  dek          String?
  authorName   String
  bodyHtml     String
  heroImageKey String?
  category     String // e.g. Announcements, Community, Research Culture — free text
  tags         String? // comma-separated, mirrors Article.keywords

  status      String    @default("DRAFT") // DRAFT | PUBLISHED
  publishedAt DateTime?
  createdById String
  views       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy User @relation(fields: [createdById], references: [id])

  @@index([type, status, publishedAt])
}
